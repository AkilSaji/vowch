<!DOCTYPE html><html  lang="en-US" dir="ltr" class="has-scrollbar is-mouse"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Privacy policy | incredibles</title><link rel="stylesheet" href="/fonts/supply-mono.css"><link rel="stylesheet" href="/fonts/frama.css"><link rel="stylesheet" href="/fonts/neue-montreal.css"><style>::-moz-selection{background:var(--color-accent);color:var(--color-white);text-shadow:none}::selection{background:var(--color-accent);color:var(--color-white);text-shadow:none}*{box-sizing:border-box;outline:none}:focus-visible{outline:2px solid var(--color-accent);outline-offset:2px}#main-content:focus{outline:none}.skip-link{position:fixed;top:0;left:0;z-index:100;padding:.75rem 1rem;background:var(--color-black);border-radius:0 0 .5rem;transform:translateY(-100%);color:var(--color-white);font-weight:300;transition:transform .2s cubic-bezier(.23,1,.32,1)}.skip-link:focus{transform:translateY(0)}body,html{position:relative;width:100%;min-height:100lvh;background:var(--color-white-darker);cursor:default;-webkit-font-smoothing:antialiased;-webkit-text-size-adjust:100%;-moz-text-size-adjust:100%;text-size-adjust:100%;text-rendering:optimizelegibility;-moz-osx-font-smoothing:grayscale}html{margin:0;font:var(--font-weight-base) var(--font-size-base)/var(--font-height-base) var(--font-family-base);letter-spacing:var(--font-spacing-base,0);scroll-padding-top:calc(var(--grid-offset)*2.5);color:var(--color-black)}html.has-scrollbar{scrollbar-width:none}body{overflow:hidden visible;font-family:inherit}</style><style>.site-head{position:fixed;top:var(--grid-offset);left:0;z-index:10;width:100%}.site-head .s__brand{position:fixed;left:var(--grid-abs-offset)}.site-head .s__logo{display:block}.site-head .s__logo img{display:block;width:2rem;height:2rem}.site-head .s__nav{position:fixed;right:var(--grid-abs-offset);gap:1.5rem}.site-head .s__menu,.site-head .s__nav{display:flex;flex-direction:row;align-items:center;justify-content:flex-end}.site-head .s__menu{gap:inherit;margin:0;padding:0;list-style:none}@media only screen and (max-width:767px){.site-head .s__menu-item--link{display:none}}.site-head .s__language-selector{display:flex;flex-direction:row;align-items:center;justify-content:center;margin:0;padding:.125rem;background:var(--color-white-darker);border-radius:.375rem;list-style:none}@media only screen and (max-width:767px){.site-head .s__language-selector{display:none}}.site-head .s__language-selector .s__language-item{margin:0;padding:0}.site-head .s__language-selector .s__language-link{display:flex;flex-direction:row;align-items:center;justify-content:center;width:1.875rem;height:1.75rem;border-radius:.3333rem;opacity:.3;color:var(--color-black);font-family:var(--font-family-supply-mono);font-size:.875rem;font-weight:500;letter-spacing:-.04em;line-height:1}.site-head .s__language-selector .s__language-link.is-active{background:var(--color-white-dark);opacity:1}.site-head .s__language-selector .s__language-link:hover{opacity:1}</style><style>.l-legal[data-v-497ffd13]{padding:10rem 0 4rem}@media only screen and (max-width:1536px){.l-legal[data-v-497ffd13]{padding:8rem 0 3rem}}@media only screen and (max-width:987px){.l-legal[data-v-497ffd13]{padding-bottom:2rem}}@media only screen and (max-width:576px),only screen and (max-width:767px)and (orientation:landscape){.l-legal[data-v-497ffd13]{padding-bottom:1rem}}.l-legal .l__content[data-v-497ffd13]{display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-start;gap:2rem;margin:0 auto;width:75%;max-width:48rem}@media only screen and (max-width:987px){.l-legal .l__content[data-v-497ffd13]{width:100%}}.l-legal .l__body[data-v-497ffd13]{padding-top:4rem;padding-bottom:4rem}@media only screen and (max-width:987px){.l-legal .l__body[data-v-497ffd13]{padding-top:3rem;padding-bottom:3rem;font-size:var(--font-size-t-xs)}}</style><style>.site-scrollbar{position:fixed;top:0;right:0;z-index:20;width:20px;height:100%}.site-scrollbar__track{position:absolute;top:0;left:0;z-index:2;width:100%;height:100%;background-color:transparent;pointer-events:none}.site-scrollbar__thumb{position:absolute;top:0;left:calc(50% - 3px);z-index:3;width:6px;height:var(--scrollbar-height,0);border-radius:999em;cursor:grab;translate:0 var(--scrollbar-top) 0;scale:1 1;transition:scale .2s cubic-bezier(.215,.61,.355,1),opacity .07s linear;will-change:opacity,scale,transform}.site-scrollbar__thumb:before{position:absolute;top:-12px;left:calc(50% - 12px);width:24px;height:calc(100% + 24px);content:""}.site-scrollbar__thumb:after{position:absolute;top:12px;bottom:12px;left:0;width:100%;height:auto;background-color:#0000004d;border-radius:inherit;transition:top .1s cubic-bezier(.215,.61,.355,1),bottom .1s cubic-bezier(.215,.61,.355,1),background-color .1s cubic-bezier(.215,.61,.355,1);content:""}.site-scrollbar__thumb:hover:after{top:6px;bottom:6px;background-color:#000c}.site-scrollbar.is-dragging,.site-scrollbar.is-dragging .site-scrollbar__thumb{cursor:grabbing}.site-scrollbar.is-dragging .site-scrollbar__thumb:after{background-color:#fff}html.is-scrollbar-dragging{-webkit-user-select:none;-moz-user-select:none;user-select:none}</style><style>.site-foot[data-v-51fde519]{padding:1.5rem 0;height:4rem;color:var(--color-gray-dark)}@media only screen and (max-width:576px){.site-foot[data-v-51fde519]{height:auto}}.site-foot .u-container[data-v-51fde519]{display:grid;align-items:center;gap:1.5rem;grid-template-columns:1fr auto 1fr}@media only screen and (max-width:576px){.site-foot .u-container[data-v-51fde519]{display:flex;flex-wrap:wrap;justify-content:space-between;gap:1.5rem}.site-foot .s__nav[data-v-51fde519]{order:3;width:100%}}.site-foot .s__copyright[data-v-51fde519]{display:block}.site-foot .s__pages[data-v-51fde519]{display:flex;flex-direction:row;align-items:center;justify-content:flex-start;gap:1.5rem;margin:0;padding:0;list-style:none}@media only screen and (max-width:576px){.site-foot .s__pages[data-v-51fde519]{justify-content:space-between}}.site-foot .s__contact[data-v-51fde519]{order:1}.site-foot .s__socials[data-v-51fde519]{display:flex;flex-direction:row;align-items:center;justify-content:flex-end;order:2;gap:.5rem;margin:0 0 0 auto;padding:0;list-style:none}@media only screen and (max-width:576px){.site-foot .s__socials[data-v-51fde519]{margin:0}}.site-foot a[data-v-51fde519]{display:block;text-decoration:none}</style><style>.btn-main{display:flex;flex-direction:row;align-items:center;justify-content:center;position:relative;padding:0;-webkit-appearance:none;-moz-appearance:none;appearance:none;background:none;border:none;cursor:pointer;font-family:var(--font-family-supply-mono);font-weight:500;letter-spacing:-.05em;line-height:1;text-decoration:none;text-transform:uppercase;white-space:nowrap}.btn-main__outer{position:relative;display:block;width:100%;overflow:hidden}.btn-main__outer:after,.btn-main__outer:before{position:absolute;top:0;left:0;z-index:1;width:100%;height:100%;background:transparent;border-radius:inherit;content:""}.btn-main__outer:before{clip-path:inset(0)}.btn-main__outer:after{z-index:5;border:1px solid rgba(43,43,43,.169)}.btn-main__hover,.btn-main__inner{display:flex;flex-direction:row;align-items:center;justify-content:center}.btn-main__inner{position:relative;z-index:2}.btn-main__inner .btn-main__icon,.btn-main__inner .btn-main__text{transition:transform .8s cubic-bezier(.23,1,.32,1);will-change:transform}.btn-main__hover{position:absolute;top:0;left:0;z-index:3;width:100%;height:100%;border-radius:inherit;clip-path:ellipse(80% 50% at 50% 152%);transition:clip-path .6s cubic-bezier(.19,1,.22,1);will-change:clip-path}.btn-main__hover .btn-main__icon,.btn-main__hover .btn-main__text{transform:translate3d(0,.5em,0);transition:transform .8s cubic-bezier(.23,1,.32,1);will-change:transform}.btn-main__hover .btn-main__text:after,.btn-main__hover .btn-main__text:before{display:block;transition:clip-path 1s cubic-bezier(.23,1,.32,1) 0s;content:attr(data-text)}.btn-main__hover .btn-main__text:before{position:absolute;top:0;left:0;clip-path:inset(0 0 0);color:var(--color-accent)}.btn-main__hover .btn-main__text:after{position:relative;clip-path:inset(100% 0 0)}.btn-main__icon{display:block;width:.75em;height:.75em;background:currentcolor;-webkit-mask-position:center;mask-position:center;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;-webkit-mask-size:contain;mask-size:contain}@media(hover:hover){.btn-main:hover .btn-main__outer:before{clip-path:inset(0 0 110%);transition:clip-path .8s cubic-bezier(.86,0,.07,1)}.btn-main:hover .btn-main__inner .btn-main__icon,.btn-main:hover .btn-main__inner .btn-main__text{transform:translate3d(0,-.75em,0);transition:transform .4s cubic-bezier(.55,-.61,.73,.04)}.btn-main:hover .btn-main__hover{clip-path:ellipse(100% 70% at 50% 50%);transition:clip-path .8s cubic-bezier(.86,0,.07,1)}.btn-main:hover .btn-main__hover .btn-main__icon,.btn-main:hover .btn-main__hover .btn-main__text{transform:translateZ(0);transition:transform .8s cubic-bezier(.19,1,.22,1) .35s}.btn-main:hover .btn-main__hover .btn-main__text:before{clip-path:inset(0 0 100%);transition:clip-path .6s cubic-bezier(.19,1,.22,1) .35s}.btn-main:hover .btn-main__hover .btn-main__text:after{clip-path:inset(0 0 0);transition:clip-path .6s cubic-bezier(.19,1,.22,1) .35s}}.btn-main--lg{font-size:1rem;font-weight:400}.btn-main--lg .btn-main__outer{padding:1rem 3rem;height:3rem;border-radius:999rem}.btn-main--md{font-size:.875rem}.btn-main--md .btn-main__outer{padding:.6875rem 1rem;border-radius:.375rem}.btn-main--sm{font-size:.75rem;letter-spacing:-.03em}.btn-main--sm .btn-main__outer{padding:.625rem .75rem;border-radius:.375rem}.btn-main--xs{font-size:.625rem;letter-spacing:-.03em}.btn-main--xs .btn-main__outer{padding:.375rem .5rem;border-radius:.25rem}.btn-main--primary.btn-main--black{color:var(--color-white-dark)}.btn-main--primary.btn-main--black .btn-main__outer:before{background:var(--color-black)}.btn-main--primary.btn-main--black .btn-main__hover{background:var(--color-white-dark);color:var(--color-black)}.btn-main--primary.btn-main--white{color:var(--color-black)}.btn-main--primary.btn-main--white .btn-main__outer:before{background:var(--color-white-dark)}.btn-main--primary.btn-main--white .btn-main__outer:after{border-color:var(--color-white-dark)}.btn-main--primary.btn-main--white .btn-main__hover{background:var(--color-black);border:1px solid var(--color-white-dark);color:var(--color-white-dark)}.btn-main--primary.btn-main--accent{color:var(--color-white)}.btn-main--primary.btn-main--accent .btn-main__outer:before{background:var(--color-accent)}.btn-main--primary.btn-main--accent .btn-main__outer:after{border-color:var(--color-accent)}.btn-main--primary.btn-main--accent .btn-main__hover{background:var(--color-white);color:var(--color-accent)}.btn-main--secondary{background:transparent}.btn-main--secondary .btn-main__outer:after{display:block;border:1px solid}.btn-main--secondary.btn-main--black{color:var(--color-black)}.btn-main--secondary.btn-main--black .btn-main__hover{background:var(--color-black);color:var(--color-white-dark)}.btn-main--secondary.btn-main--white{border-color:var(--color-white-dark);color:var(--color-white-dark)}.btn-main--secondary.btn-main--white .btn-main__hover{background:var(--color-white-dark);color:var(--color-black)}.btn-main--icon{padding:0;width:1.5rem;height:1.5rem;border-radius:.25rem}.btn-main--icon .btn-main__outer{padding:0;width:100%;height:100%}.btn-main--icon .btn-main__hover,.btn-main--icon .btn-main__inner{gap:0;height:100%}.btn-main--icon .btn-main__text{position:absolute;margin:-1px;padding:0;width:1px;height:1px;border:0;clip-path:rect(0,0,0,0);overflow:hidden}</style><link rel="stylesheet" href="/_nuxt/entry.1Cj3YW7s.css" crossorigin><link rel="preload" href="/fonts/supply-mono.css" as="style"><link rel="preload" href="/fonts/frama.css" as="style"><link rel="preload" href="/fonts/neue-montreal.css" as="style"><link rel="preload" as="fetch" crossorigin="anonymous" href="/privacy/_payload.json?9bdc0ec3-5189-4495-8b2b-16b13c5bcaed"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/B2Phc4Qb.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/DdWAC-bf.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/6ON4gZRy.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/CQmIGG9a.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/bsXMvv-l.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/Bah3IIkX.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/Bl1peWe-.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/C0AaKDGT.js"><link rel="modulepreload" as="script" crossorigin href="/_nuxt/FFX9UyLS.js"><script type="module" src="/_nuxt/B2Phc4Qb.js" crossorigin></script><link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96"><link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg"><link rel="shortcut icon" href="/favicon/favicon.ico"><link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png"><link rel="manifest" href="/favicon/site.webmanifest"><meta property="og:type" content="website"><meta property="og:site_name" content="incredibles"><meta name="twitter:card" content="summary_large_image"><meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"><link id="i18n-xd" rel="alternate" href="https://incredibles.dev/privacy/" hreflang="x-default"><link id="i18n-alt-fr" rel="alternate" href="https://incredibles.dev/fr/privacy/" hreflang="fr"><link id="i18n-alt-fr-FR" rel="alternate" href="https://incredibles.dev/fr/privacy/" hreflang="fr-FR"><link id="i18n-alt-en" rel="alternate" href="https://incredibles.dev/privacy/" hreflang="en"><link id="i18n-alt-en-US" rel="alternate" href="https://incredibles.dev/privacy/" hreflang="en-US"><link rel="canonical" href="https://incredibles.dev/privacy"><meta property="og:url" content="https://incredibles.dev/privacy"><meta property="og:locale" content="en_US"><meta property="og:locale:alternate" content="fr_FR"><meta property="og:image" content="https://incredibles.dev/incredibles-social-bd.jpg?v=2"><meta name="twitter:image" content="https://incredibles.dev/incredibles-social-bd.jpg?v=2"><meta name="description" content="How incredibles collects, stores and uses personal data, with rights and disclosures under the EU GDPR, UK GDPR and US state privacy laws (CCPA/CPRA and others)."><meta property="og:title" content="Privacy policy"><meta property="og:description" content="How incredibles collects, stores and uses personal data, with rights and disclosures under the EU GDPR, UK GDPR and US state privacy laws (CCPA/CPRA and others)."><script id="unhead:payload" type="application/json">{"titleTemplate":"%s %separator %siteName"}</script></head><body><div id="__nuxt"><!--[--><a href="#main-content" class="skip-link">Skip to main content</a><header class="site-head"><div class="s__brand"><a href="/" class="s__logo"><img src="data:image/svg+xml,%3csvg%20width=&#39;32&#39;%20height=&#39;32&#39;%20viewBox=&#39;0%200%2032%2032&#39;%20fill=&#39;none&#39;%20xmlns=&#39;http://www.w3.org/2000/svg&#39;%3e%3crect%20width=&#39;32&#39;%20height=&#39;32&#39;%20rx=&#39;6&#39;%20fill=&#39;%232B2B2B&#39;/%3e%3cpath%20d=&#39;M16.8895%208H20.5039L17.8073%2016L15.1108%2024H11.4965L16.8895%208Z&#39;%20fill=&#39;%23FAFAFA&#39;/%3e%3c/svg%3e" alt="incredibles" width="32" height="32"></a></div><nav class="s__nav"><ul class="s__menu"><!--[--><li class="s__menu-item s__menu-item--link"><a href="#pricing" class="btn-main btn-main--secondary btn-main--black btn-main--md s__menu-link"><span class="btn-main__outer"><span class="btn-main__inner"><span class="btn-main__text u-height-fix"><!--[-->Pricing<!--]--></span><!----></span><span class="btn-main__hover"><span class="btn-main__text u-height-fix" data-text="Pricing"></span><!----></span></span></a></li><!--]--><li class="s__menu-item s__menu-item--cta"><button class="btn-main btn-main--primary btn-main--black btn-main--md s__menu-link s__menu-link--cta"><span class="btn-main__outer"><span class="btn-main__inner"><span class="btn-main__text u-height-fix"><!--[-->Start a conversation<!--]--></span><!----></span><span class="btn-main__hover"><span class="btn-main__text u-height-fix" data-text="Start a conversation"></span><!----></span></span></button></li></ul><ul class="s__language-selector" aria-label="Language"><!--[--><li class="s__language-item"><a href="/fr/privacy" class="s__language-link" hreflang="fr-FR" aria-label="French"><span class="u-height-fix">FR</span></a></li><li class="s__language-item"><a href="/privacy" class="s__language-link is-active" hreflang="en-US" aria-label="English" aria-current="page"><span class="u-height-fix">EN</span></a></li><!--]--></ul></nav></header><main id="main-content" tabindex="-1"><div class="l-legal" data-v-497ffd13><div class="u-container" data-v-497ffd13><div class="l__content" data-v-497ffd13><h1 class="l__title t-h-lg u-white-box" data-v-497ffd13>Privacy policy</h1><div class="l__body u-white-box rte t-t-sm" data-content-id="privacy_en/en/privacy.md" data-v-497ffd13><h2 id="_1-who-we-are-and-scope"><a href="#_1-who-we-are-and-scope"><!--[-->1. Who we are and scope<!--]--></a></h2><p><!--[-->This site is operated by incredibles, a senior web development studio based in France. For any privacy-related question, you can reach us at <a href="/cdn-cgi/l/email-protection#6b03022b020508190e0f0209070e18450f0e1d" rel="noopener noreferrer"><!--[--><span class="__cf_email__" data-cfemail="caa2a38aa3a4a9b8afaea3a8a6afb9e4aeafbc">[email&#160;protected]</span><!--]--></a>.<!--]--></p><p><!--[-->This policy applies to all visitors of incredibles.dev, regardless of where you are located. We provide rights and information appropriate to your jurisdiction, including under the EU General Data Protection Regulation (GDPR), the UK GDPR and the Data Protection Act 2018, and applicable US state privacy laws such as the California Consumer Privacy Act (CCPA/CPRA), the Virginia Consumer Data Protection Act, the Colorado Privacy Act, the Connecticut Data Privacy Act and similar laws.<!--]--></p><h2 id="_2-what-data-we-collect"><a href="#_2-what-data-we-collect"><!--[-->2. What data we collect<!--]--></a></h2><p><!--[-->We collect the data you give us explicitly through the contact form on this site — name, email address, company name, company website, budget range, estimated start date, expected launch date and the message you send. We also collect technical logs that web servers generate automatically (IP address, user agent, requested URL, timestamp) and we apply basic rate limiting on form submissions to prevent abuse.<!--]--></p><p><!--[-->We use <a href="https://plausible.io" rel="nofollow"><!--[-->Plausible Analytics<!--]--></a> to measure aggregated traffic on this site. Plausible is a privacy-friendly analytics service that does not use cookies, does not track users across sites, and does not collect any personal data — it only records anonymous, aggregated metrics such as page views, referrers and country-level location. We do not use any advertising or marketing trackers.<!--]--></p><h2 id="_3-why-we-use-this-data"><a href="#_3-why-we-use-this-data"><!--[-->3. Why we use this data<!--]--></a></h2><p><!--[-->We use contact form submissions to respond to your enquiry, scope and quote projects, sign agreements, deliver our services and bill them. We use technical logs and rate-limit data for security, troubleshooting and abuse prevention.<!--]--></p><h2 id="_4-legal-basis"><a href="#_4-legal-basis"><!--[-->4. Legal basis<!--]--></a></h2><p><!--[-->Under the EU GDPR and the UK GDPR, our processing relies on the following bases: your consent when you submit the form, the performance of a contract or pre-contractual steps when we discuss and run an engagement with you, and our legitimate interest in operating and securing this website. For visitors in US states with privacy laws, we process personal information only for the purposes disclosed in this policy and we do not sell or share personal information for cross-context behavioral advertising.<!--]--></p><h2 id="_5-who-has-access"><a href="#_5-who-has-access"><!--[-->5. Who has access<!--]--></a></h2><p><!--[-->The two co-founders of incredibles have access to the data submitted through the form. We rely on the following third-party processors to operate the site and respond to enquiries: our email provider, our hosting provider, a spreadsheet service used to store enquiry data, and Plausible Analytics for anonymous aggregated traffic measurement. These providers process data on our behalf under their own data-protection terms.<!--]--></p><h2 id="_6-international-transfers"><a href="#_6-international-transfers"><!--[-->6. International transfers<!--]--></a></h2><p><!--[-->Our business is established in France (EU). Some of the third-party processors we use are based outside the European Economic Area or the United Kingdom — for example in the United States. When this is the case, transfers are covered by appropriate safeguards: the European Commission&#39;s Standard Contractual Clauses (SCCs) for transfers from the EEA, and the UK International Data Transfer Agreement (IDTA) or UK Addendum to the SCCs for transfers from the United Kingdom. Where relevant, we rely on adequacy decisions (such as the EU-US Data Privacy Framework) and we carry out transfer impact assessments.<!--]--></p><h2 id="_7-how-long-we-keep-data"><a href="#_7-how-long-we-keep-data"><!--[-->7. How long we keep data<!--]--></a></h2><p><!--[-->We keep contact-form submissions for as long as they are useful to respond to your enquiry and follow up on a potential engagement, and for up to 36 months after the last contact. Data tied to invoiced engagements is kept for the legal accounting retention period (10 years under French law). Server logs are kept for a maximum of 12 months.<!--]--></p><h2 id="_8-your-rights"><a href="#_8-your-rights"><!--[-->8. Your rights<!--]--></a></h2><p><!--[-->To exercise any of the rights described below, write to <a href="/cdn-cgi/l/email-protection#cba3a28ba2a5a8b9aeafa2a9a7aeb8e5afaebd" rel="noopener noreferrer"><!--[--><span class="__cf_email__" data-cfemail="ea8283aa838489988f8e8388868f99c48e8f9c">[email&#160;protected]</span><!--]--></a>. We respond within 30 days (and within 45 days for US state-law requests, extendable once where permitted by law). We will not discriminate against you for exercising any of these rights.<!--]--></p><h3 id="if-you-are-in-the-european-economic-area"><a href="#if-you-are-in-the-european-economic-area"><!--[-->If you are in the European Economic Area<!--]--></a></h3><p><!--[-->Under the EU GDPR you can request access to your personal data, ask for it to be rectified or deleted, restrict or object to its processing, request its portability, and withdraw any consent you previously gave. You can lodge a complaint with your local supervisory authority — in France, the CNIL (<a href="https://www.cnil.fr" rel="nofollow"><!--[-->cnil.fr<!--]--></a>).<!--]--></p><h3 id="if-you-are-in-the-united-kingdom"><a href="#if-you-are-in-the-united-kingdom"><!--[-->If you are in the United Kingdom<!--]--></a></h3><p><!--[-->Under the UK GDPR and the Data Protection Act 2018 you have the same rights as listed above. You can lodge a complaint with the UK Information Commissioner&#39;s Office (ICO — <a href="https://ico.org.uk" rel="nofollow"><!--[-->ico.org.uk<!--]--></a>).<!--]--></p><h3 id="if-you-are-in-the-united-states"><a href="#if-you-are-in-the-united-states"><!--[-->If you are in the United States<!--]--></a></h3><p><!--[-->Depending on your state of residence, you may have rights under applicable state privacy laws, including the right to know what personal information we collect and the purposes for which we use it, the right to access, correct or delete that information, the right to portability, and the right to opt out of certain processing. We do not sell or share personal information, we do not use personal information for cross-context behavioral advertising, and we do not use sensitive personal information for purposes that would require a separate right to limit such use. California residents may designate an authorized agent to make requests on their behalf. Residents of California, Virginia, Colorado, Connecticut, Utah and other US states with comparable laws may exercise the rights granted to them by their state&#39;s laws by writing to us at the address above.<!--]--></p><h2 id="_9-cookies"><a href="#_9-cookies"><!--[-->9. Cookies<!--]--></a></h2><p><!--[-->This website uses only the strictly necessary cookies required for the site to function (such as language preference). Our analytics provider, Plausible, does not use cookies. We do not set any marketing or third-party advertising cookies, and we do not need to display a cookie consent banner because no consent-requiring cookies are deposited.<!--]--></p><h2 id="_10-updates"><a href="#_10-updates"><!--[-->10. Updates<!--]--></a></h2><p><!--[-->We may update this privacy policy from time to time. The current version is the one published on this page.<!--]--></p><p><!--[--><em><!--[-->Last updated: 12 May 2026.<!--]--></em><!--]--></p></div></div></div></div></main><!----><footer class="site-foot t-t-3xs rte" data-v-51fde519><div class="u-container" data-v-51fde519><nav class="s__nav" data-v-51fde519><ul class="s__pages" data-v-51fde519><li class="s__page" data-v-51fde519><a href="/legals/" class="s__link" data-v-51fde519>Legals</a></li><li class="s__page" data-v-51fde519><a aria-current="page" href="/privacy/" class="router-link-active router-link-exact-active s__link" data-v-51fde519>Privacy</a></li></ul></nav><div class="s__contact" data-v-51fde519><a href="/cdn-cgi/l/email-protection#4f27260f26212c3d2a2b262d232a3c612b2a39" data-v-51fde519><span class="__cf_email__" data-cfemail="dbb3b29bb2b5b8a9bebfb2b9b7bea8f5bfbead">[email&#160;protected]</span></a></div><ul class="s__socials" data-v-51fde519><li class="s__social" data-v-51fde519><a href="https://www.linkedin.com/company/incredibles-dev/" class="s__social__link" target="_blank" rel="noopener noreferrer" data-v-51fde519> LinkedIn </a></li></ul></div></footer><!--]--></div><div id="teleports"></div><script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>window.__NUXT__={};window.__NUXT__.config={public:{studio:{route:"/_studio",dev:false,development:{server:""},ai:{enabled:false,context:{collectionName:"studio",contentFolder:".studio"},experimental:{collectionContext:false}},repository:{provider:"github",owner:"incredibles-dev",repo:"incredibles-v3",branch:"prd",rootDir:"",private:true,instanceUrl:""},i18n:{defaultLocale:"en"},media:{external:false,publicUrl:"/home/runner/work/incredibles-v3/incredibles-v3/public",maxFileSize:10485760,allowedTypes:["image/*","video/*","audio/*"],prefix:"studio"},git:{commit:{messagePrefix:""}},iconLibraries:"",commands:{exclude:[]}},plausible:{enabled:false,hashMode:false,domain:"incredibles.dev",ignoredHostnames:["localhost"],ignoreSubDomains:false,apiHost:"https://plausible.io",autoPageviews:true,autoOutboundTracking:false,fileDownloads:false,formSubmissions:false,logIgnoredEvents:false,proxy:false,proxyBaseEndpoint:"/_plausible"},"nuxt-seo-utils-version":"8.1.11","seo-utils":{canonicalQueryWhitelist:["page","sort","filter","search","q","category","tag"],canonicalLowercase:true,tagPriority:"low",separator:"",titleSeparator:""},mdc:{components:{prose:true,map:{},customElements:[]},headings:{anchorLinks:{h1:false,h2:true,h3:true,h4:true,h5:false,h6:false}},highlight:{noApiRoute:true,highlighter:"shiki",theme:{default:"github-light",dark:"github-dark"},shikiEngine:"oniguruma",langs:["js","jsx","json","ts","tsx","vue","css","html"